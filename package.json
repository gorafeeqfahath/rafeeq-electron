{
  "name": "my-electron-app",
  "version": "1.0.0",
  "productName": "Rafeeq Vendor Dashboard",
  "description": "Test App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "package-mac": "electron-packager . --overwrite --asar=true --platform=darwin --arch=x64 --icon=assets/icons/mac/favicon.icns --prune=true --out=release-builds",
    "package-win": "electron-packager . --overwrite --asar=true --platform=win32 --arch=ia32 --icon=assets/icons/win/favicon.ico --prune=true --out=release-builds --version-string.CompanyName=CE --version-string.FileDescription=CE --version-string.ProductName=\"Rafeeq Vendor Dashboard\"",
    "package-linux": "electron-packager . --overwrite --asar=true --platform=linux --arch=x64 --icon=assets/icons/png/favicon.png --prune=true --out=release-builds",
    "create-installer-mac": "electron-installer-dmg ./release-builds/Rafeeq\\ Vendor\\ app-darwin-x64/Rafeeq\\ Dashboard\\ app.app rafeeq-vendor-dashboard --out=release-builds --overwrite --icon=assets/icons/mac/icon.icns",
    "create-installer-win": "node installers/windows/createinstaller.js"
  },
  "keywords": [],
  "author": "mtmfahath",
  "license": "ISC",
  "devDependencies": {
    "electron": "^12.0.0",
    "electron-installer-dmg": "^3.0.0",
    "electron-packager": "^15.2.0",
    "electron-winstaller": "^5.0.0"
  }
}
